<header class="topbar">
  <a class="brand" href="<%= currentUser ? '/app' : '/login' %>" aria-label="일본어 학습 보조 홈">
    <span class="brand-mark">日</span>
    <span class="brand-text">일본어 학습 보조</span>
  </a>
  <% if (currentUser) { %>
    <nav class="nav-links" aria-label="주요 메뉴">
      <a class="<%= path === '/app' ? 'active' : '' %>" href="/app">분석</a>
      <% if (currentUser.role === 'admin') { %>
        <a class="<%= path === '/admin' ? 'active' : '' %>" href="/admin">관리자</a>
      <% } %>
      <form action="/logout" method="post" class="logout-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="ghost-button">로그아웃</button>
      </form>
    </nav>
  <% } %>
</header>
