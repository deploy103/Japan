NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-random-characters
DATABASE_PATH=./data/app.sqlite
# Set true only when serving through HTTPS.
COOKIE_SECURE=false

# Optional. If set, /api/analyze uses this server first and falls back to
# local word-by-word translation if the server is unavailable.
# LIBRETRANSLATE_URL=http://127.0.0.1:5000
# LIBRETRANSLATE_API_KEY=

# Optional. Used for OpenAI translation, Korean-to-Japanese translation, OCR, and example generation.
# Never commit a real key.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
